.TH "libnvmf_context_set_discovery_hooks" 9 "libnvmf_context_set_discovery_hooks" "June 2026" "libnvme API manual" LINUX
.SH NAME
libnvmf_context_set_discovery_hooks \- Set discovery hooks for context
.SH SYNOPSIS
.B "int" libnvmf_context_set_discovery_hooks
.BI "(struct libnvmf_context *fctx "  ","
.BI "void (*discovery_log)(struct libnvmf_context *fctx, bool connect, struct nvmf_discovery_log *log, uint64_t numrec, void *user_data) "  ","
.BI "int (*parser_init)(struct libnvmf_context *fctx, void *user_data) "  ","
.BI "void (*parser_cleanup)(struct libnvmf_context *fctx, void *user_data) "  ","
.BI "int (*parser_next_line)(struct libnvmf_context *fctx, void *user_data) "  ");"
.SH ARGUMENTS
.IP "fctx" 12
Fabrics context
.IP "discovery_log" 12
Hook for discovery log events
.IP "parser_init" 12
Hook to initialize parser
.IP "parser_cleanup" 12
Hook to cleanup parser
.IP "parser_next_line" 12
Hook to parse next line
.SH "DESCRIPTION"
Sets the hooks used during discovery operations for the given context.
.SH "RETURN"
0 on success, negative error code otherwise.
