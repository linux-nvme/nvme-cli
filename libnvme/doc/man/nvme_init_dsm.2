.TH "nvme_init_dsm" 9 "nvme_init_dsm" "April 2026" "libnvme API manual" LINUX
.SH NAME
nvme_init_dsm \- Initialize passthru command for NVMEe I/O Data Set Management
.SH SYNOPSIS
.B "void" nvme_init_dsm
.BI "(struct libnvme_passthru_cmd *cmd "  ","
.BI "__u32 nsid "  ","
.BI "__u16 nr "  ","
.BI "__u8 idr "  ","
.BI "__u8 idw "  ","
.BI "__u8 ad "  ","
.BI "void *data "  ","
.BI "__u32 len "  ");"
.SH ARGUMENTS
.IP "cmd" 12
Passthru command to use
.IP "nsid" 12
Namespace identifier
.IP "nr" 12
Number of block ranges in the data set management attributes
.IP "idr" 12
DSM Integral Dataset for Read attribute
.IP "idw" 12
DSM Integral Dataset for Write attribute
.IP "ad" 12
DSM Deallocate attribute
.IP "data" 12
User space destination address to transfer the data
.IP "len" 12
Length of provided user buffer to hold the log data in bytes
