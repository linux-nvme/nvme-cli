.TH "nvme_init_get_log" 9 "nvme_init_get_log" "April 2026" "libnvme API manual" LINUX
.SH NAME
nvme_init_get_log \- Initialize passthru command for NVMe Admin Get Log
.SH SYNOPSIS
.B "void" nvme_init_get_log
.BI "(struct libnvme_passthru_cmd *cmd "  ","
.BI "__u32 nsid "  ","
.BI "enum nvme_cmd_get_log_lid lid "  ","
.BI "enum nvme_csi csi "  ","
.BI "void *data "  ","
.BI "__u32 len "  ");"
.SH ARGUMENTS
.IP "cmd" 12
Passthru command to use
.IP "nsid" 12
Namespace identifier, if applicable
.IP "lid" 12
Log Page Identifier, see \fIenum nvme_cmd_get_log_lid\fP
.IP "csi" 12
Command set identifier, see \fIenum nvme_csi\fP for known values
.IP "data" 12
User space destination address to transfer the data
.IP "len" 12
Length of provided user buffer to hold the log data in bytes
