.TH "nvme_init_format_nvm" 9 "nvme_init_format_nvm" "April 2026" "libnvme API manual" LINUX
.SH NAME
nvme_init_format_nvm \- Initialize passthru command for Format NVM
.SH SYNOPSIS
.B "void" nvme_init_format_nvm
.BI "(struct libnvme_passthru_cmd *cmd "  ","
.BI "__u32 nsid "  ","
.BI "__u8 lbaf "  ","
.BI "enum nvme_cmd_format_mset mset "  ","
.BI "enum nvme_cmd_format_pi pi "  ","
.BI "enum nvme_cmd_format_pil pil "  ","
.BI "enum nvme_cmd_format_ses ses "  ");"
.SH ARGUMENTS
.IP "cmd" 12
Passthru command to use
.IP "nsid" 12
Namespace ID to format
.IP "lbaf" 12
Logical block address format
.IP "mset" 12
Metadata settings (extended or separated)
.IP "pi" 12
Protection information type
.IP "pil" 12
Protection information location (beginning or end)
.IP "ses" 12
Secure erase settings
.SH "DESCRIPTION"
Initializes the passthru command buffer for the Format NVM command.
