.TH "libnvme_insert_tls_key" 9 "libnvme_insert_tls_key" "April 2026" "libnvme API manual" LINUX
.SH NAME
libnvme_insert_tls_key \- Derive and insert TLS key
.SH SYNOPSIS
.B "int" libnvme_insert_tls_key
.BI "(struct libnvme_global_ctx *ctx "  ","
.BI "const char *keyring "  ","
.BI "const char *key_type "  ","
.BI "const char *hostnqn "  ","
.BI "const char *subsysnqn "  ","
.BI "int hmac "  ","
.BI "unsigned char *configured_key "  ","
.BI "int key_len "  ","
.BI "long *key "  ");"
.SH ARGUMENTS
.IP "ctx" 12
struct libnvme_global_ctx object
.IP "keyring" 12
Keyring to use
.IP "key_type" 12
Type of the resulting key
.IP "hostnqn" 12
Host NVMe Qualified Name
.IP "subsysnqn" 12
Subsystem NVMe Qualified Name
.IP "hmac" 12
HMAC algorithm
.IP "configured_key" 12
Configured key data to derive the key from
.IP "key_len" 12
Length of \fIconfigured_key\fP
.IP "key" 12
Key serial to return
.SH "DESCRIPTION"
Derives a 'retained' TLS key as specified in NVMe TCP 1.0a and
stores it as type \fIkey_type\fP in the keyring specified by \fIkeyring\fP.
.SH "RETURN"
0 on success or negative error code otherwise
