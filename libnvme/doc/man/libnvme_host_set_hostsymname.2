.TH "libnvme_host_set_hostsymname" 9 "libnvme_host_set_hostsymname" "April 2026" "libnvme API manual" LINUX
.SH NAME
libnvme_host_set_hostsymname \- Set hostsymname.
.SH SYNOPSIS
.B "void" libnvme_host_set_hostsymname
.BI "(struct libnvme_host *p "  ","
.BI "const char *hostsymname "  ");"
.SH ARGUMENTS
.IP "p" 12
The \fIstruct libnvme_host\fP instance to update.
.IP "hostsymname" 12
New string; a copy is stored. Pass NULL to clear.
