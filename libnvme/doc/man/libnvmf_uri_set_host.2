.TH "libnvmf_uri_set_host" 9 "libnvmf_uri_set_host" "April 2026" "libnvme API manual" LINUX
.SH NAME
libnvmf_uri_set_host \- Set host.
.SH SYNOPSIS
.B "void" libnvmf_uri_set_host
.BI "(struct libnvmf_uri *p "  ","
.BI "const char *host "  ");"
.SH ARGUMENTS
.IP "p" 12
The \fIstruct libnvmf_uri\fP instance to update.
.IP "host" 12
New string; a copy is stored. Pass NULL to clear.
