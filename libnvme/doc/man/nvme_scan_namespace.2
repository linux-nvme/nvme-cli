.TH "nvme_scan_namespace" 9 "nvme_scan_namespace" "March 2026" "libnvme API manual" LINUX
.SH NAME
nvme_scan_namespace \- scan namespace based on sysfs name
.SH SYNOPSIS
.B "int" nvme_scan_namespace
.BI "(struct nvme_global_ctx *ctx "  ","
.BI "const char *name "  ","
.BI "nvme_ns_t *ns "  ");"
.SH ARGUMENTS
.IP "ctx" 12
\fIstruct nvme_global_ctx\fP object
.IP "name" 12
sysfs name of the namespace to scan
.IP "ns" 12
\fInvme_ns_t\fP object to return
.SH "RETURN"
0 on success or negative error code otherwise
