.TH "nvmf_context_set_discovery_cbs" 9 "nvmf_context_set_discovery_cbs" "March 2026" "libnvme API manual" LINUX
.SH NAME
nvmf_context_set_discovery_cbs \- Set discovery callbacks for context
.SH SYNOPSIS
.B "int" nvmf_context_set_discovery_cbs
.BI "(struct nvmf_context *fctx "  ","
.BI "void (*discovery_log)(struct nvmf_context *fctx, bool connect, struct nvmf_discovery_log *log, uint64_t numrec, void *user_data) "  ","
.BI "int (*parser_init)(struct nvmf_context *fctx, void *user_data) "  ","
.BI "void (*parser_cleanup)(struct nvmf_context *fctx, void *user_data) "  ","
.BI "int (*parser_next_line)(struct nvmf_context *fctx, void *user_data) "  ");"
.SH ARGUMENTS
.IP "fctx" 12
Fabrics context
.IP "discovery_log" 12
Callback for discovery log events
.IP "parser_init" 12
Callback to initialize parser
.IP "parser_cleanup" 12
Callback to cleanup parser
.IP "parser_next_line" 12
Callback to parse next line
.SH "DESCRIPTION"
Sets the callbacks used during discovery operations for the given context.
.SH "RETURN"
0 on success, or a negative error code on failure.
