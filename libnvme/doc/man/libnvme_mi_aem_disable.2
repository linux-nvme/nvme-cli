.TH "libnvme_mi_aem_disable" 9 "libnvme_mi_aem_disable" "April 2026" "libnvme API manual" LINUX
.SH NAME
libnvme_mi_aem_disable \- Disable AE on the provided endpoint
.SH SYNOPSIS
.B "int" libnvme_mi_aem_disable
.BI "(libnvme_mi_ep_t ep "  ");"
