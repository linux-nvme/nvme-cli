.TH "nvme_init_set_features_lba_range" 9 "nvme_init_set_features_lba_range" "April 2026" "libnvme API manual" LINUX
.SH NAME
nvme_init_set_features_lba_range \- Initialize passthru command for LBA Range
.SH SYNOPSIS
.B "void" nvme_init_set_features_lba_range
.BI "(struct libnvme_passthru_cmd *cmd "  ","
.BI "__u32 nsid "  ","
.BI "bool sv "  ","
.BI "__u8 num "  ","
.BI "struct nvme_lba_range_type *data "  ");"
.SH ARGUMENTS
.IP "cmd" 12
Passthru command to use
.IP "nsid" 12
Namespace ID
.IP "sv" 12
Save value across power states
.IP "num" 12
Number of ranges in \fIdata\fP
.IP "data" 12
User address of feature data
.SH "DESCRIPTION"
Initializes the passthru command buffer for the Set Features command with
FID value NVME_FEAT_FID_LBA_RANGE
