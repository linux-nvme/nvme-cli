.TH "nvmf_discovery_nbft" 9 "nvmf_discovery_nbft" "March 2026" "libnvme API manual" LINUX
.SH NAME
nvmf_discovery_nbft \- Perform discovery using NBFT
.SH SYNOPSIS
.B "int" nvmf_discovery_nbft
.BI "(struct nvme_global_ctx *ctx "  ","
.BI "struct nvmf_context *fctx "  ","
.BI "bool connect "  ","
.BI "char *nbft_path "  ");"
.SH ARGUMENTS
.IP "ctx" 12
Global context
.IP "fctx" 12
Fabrics context
.IP "connect" 12
Whether to connect discovered subsystems
.IP "nbft_path" 12
Path to NBFT file
.SH "DESCRIPTION"
Performs discovery using the specified NBFT file.
.SH "RETURN"
0 on success, or a negative error code on failure.
