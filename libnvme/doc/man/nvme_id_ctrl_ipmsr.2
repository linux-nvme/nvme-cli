.TH "libnvme" 9 "enum nvme_id_ctrl_ipmsr" "April 2026" "API Manual" LINUX
.SH NAME
enum nvme_id_ctrl_ipmsr \- Interval Power Measurement Sample Rate
.SH SYNOPSIS
enum nvme_id_ctrl_ipmsr {
.br
.BI "    NVME_CTRL_IPMSR_SRS_SHIFT"
, 
.br
.br
.BI "    NVME_CTRL_IPMSR_SRV_SHIFT"
, 
.br
.br
.BI "    NVME_CTRL_IPMSR_SRS_MASK"
, 
.br
.br
.BI "    NVME_CTRL_IPMSR_SRV_MASK"

};
.SH Constants
.IP "NVME_CTRL_IPMSR_SRS_SHIFT" 12
Shift amount to get the Sample Rate
Scale from the \fIstruct nvme_id_ctrl\fP.ipmsr field.
.IP "NVME_CTRL_IPMSR_SRV_SHIFT" 12
Shift amount to get the Sample Rate
Value from the \fIstruct nvme_id_ctrl\fP.ipmsr field.
.IP "NVME_CTRL_IPMSR_SRS_MASK" 12
Mask to get the Sample Rate Scale
from the \fIstruct nvme_id_ctrl\fP.ipmsr field.
.IP "NVME_CTRL_IPMSR_SRV_MASK" 12
Mask to get the Sample Rate Value
from the \fIstruct nvme_id_ctrl\fP.ipmsr field.
