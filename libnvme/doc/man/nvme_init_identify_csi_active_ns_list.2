.TH "nvme_init_identify_csi_active_ns_list" 9 "nvme_init_identify_csi_active_ns_list" "April 2026" "libnvme API manual" LINUX
.SH NAME
nvme_init_identify_csi_active_ns_list \- Initialize passthru command for Active namespace ID list
.SH SYNOPSIS
.B "void" nvme_init_identify_csi_active_ns_list
.BI "(struct libnvme_passthru_cmd *cmd "  ","
.BI "__u32 nsid "  ","
.BI "enum nvme_csi csi "  ","
.BI "struct nvme_ns_list *ns_list "  ");"
.SH ARGUMENTS
.IP "cmd" 12
Command data structure to initialize
.IP "nsid" 12
Return namespaces greater than this identifier
.IP "csi" 12
Command Set Identifier
.IP "ns_list" 12
User space destination address to transfer the data
.SH "DESCRIPTION"
Initializes the passthru command buffer for the Identify command with
CNS value NVME_IDENTIFY_CNS_CSI_NS_ACTIVE_LIST.
