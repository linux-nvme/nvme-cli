.TH "nvme_init_compare" 9 "nvme_init_compare" "April 2026" "libnvme API manual" LINUX
.SH NAME
nvme_init_compare \- Initialize passthru command for a user compare command
.SH SYNOPSIS
.B "void" nvme_init_compare
.BI "(struct libnvme_passthru_cmd *cmd "  ","
.BI "__u32 nsid "  ","
.BI "__u64 slba "  ","
.BI "__u16 nlb "  ","
.BI "__u16 control "  ","
.BI "__u8 cev "  ","
.BI "void *data "  ","
.BI "__u32 data_len "  ","
.BI "void *metadata "  ","
.BI "__u32 metadata_len "  ");"
.SH ARGUMENTS
.IP "cmd" 12
Passthru command to use
.IP "nsid" 12
Namespace ID
.IP "slba" 12
Starting logical block
.IP "nlb" 12
Number of logical blocks (0-based)
.IP "control" 12
Command control flags, see \fIenum nvme_io_control_flags\fP.
.IP "cev" 12
Command Extension Value (CETYPE is non-zero)
.IP "data" 12
Pointer to user address of the data buffer
.IP "data_len" 12
Length of user buffer, \fIdata\fP, in bytes
.IP "metadata" 12
Pointer to user address of the metadata buffer
.IP "metadata_len" 12
Length of user buffer, \fImetadata\fP, in bytes
.SH "DESCRIPTION"
Initializes the passthru command buffer for the Compare command.
