.TH "nvme_init_identify_active_ns_list" 9 "nvme_init_identify_active_ns_list" "April 2026" "libnvme API manual" LINUX
.SH NAME
nvme_init_identify_active_ns_list \- Initialize passthru command for Active Namespaces ID list
.SH SYNOPSIS
.B "void" nvme_init_identify_active_ns_list
.BI "(struct libnvme_passthru_cmd *cmd "  ","
.BI "__u32 nsid "  ","
.BI "struct nvme_ns_list *list "  ");"
.SH ARGUMENTS
.IP "cmd" 12
Command data structure to initialize
.IP "nsid" 12
Namespace identifier
.IP "list" 12
User space destination address to transfer the data
.SH "DESCRIPTION"
Initializes the passthru command buffer for the Identify command with
CNS value NVME_IDENTIFY_CNS_NS_ACTIVE_LIST.
