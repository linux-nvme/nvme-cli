.TH "nvme_init_get_log_lba_status" 9 "nvme_init_get_log_lba_status" "April 2026" "libnvme API manual" LINUX
.SH NAME
nvme_init_get_log_lba_status \- Initialize passthru command for Retrieve LBA Status
.SH SYNOPSIS
.B "void" nvme_init_get_log_lba_status
.BI "(struct libnvme_passthru_cmd *cmd "  ","
.BI "__u64 lpo "  ","
.BI "void *log "  ","
.BI "__u32 len "  ");"
.SH ARGUMENTS
.IP "cmd" 12
Passthru command to use
.IP "lpo" 12
Offset to the start of the log page
.IP "log" 12
User address to store the log page
.IP "len" 12
The allocated length of the log page
.SH "DESCRIPTION"
Initializes the passthru command buffer for the Get Log command with
LID value NVME_LOG_LID_LBA_STATUS
