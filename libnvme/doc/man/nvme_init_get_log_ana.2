.TH "nvme_init_get_log_ana" 9 "nvme_init_get_log_ana" "April 2026" "libnvme API manual" LINUX
.SH NAME
nvme_init_get_log_ana \- Initialize passthru command for Asymmetric Namespace Access
.SH SYNOPSIS
.B "void" nvme_init_get_log_ana
.BI "(struct libnvme_passthru_cmd *cmd "  ","
.BI "enum nvme_log_ana_lsp lsp "  ","
.BI "__u64 lpo "  ","
.BI "void *log "  ","
.BI "__u32 len "  ");"
.SH ARGUMENTS
.IP "cmd" 12
Passthru command to use
.IP "lsp" 12
Log specific, see \fIenum nvme_get_log_ana_lsp\fP
.IP "lpo" 12
Offset to the start of the log page
.IP "log" 12
User address to store the ana log
.IP "len" 12
The allocated length of the log page
.SH "DESCRIPTION"
Initializes the passthru command buffer for the Get Log command with
LID value NVME_LOG_LID_ANA.
