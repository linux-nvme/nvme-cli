.TH "nvme_init_identify_ns_ctrl_list" 9 "nvme_init_identify_ns_ctrl_list" "April 2026" "libnvme API manual" LINUX
.SH NAME
nvme_init_identify_ns_ctrl_list \- Initialize passhtru command for Controller List
.SH SYNOPSIS
.B "void" nvme_init_identify_ns_ctrl_list
.BI "(struct libnvme_passthru_cmd *cmd "  ","
.BI "__u32 nsid "  ","
.BI "__u16 cntid "  ","
.BI "struct nvme_ctrl_list *cntlist "  ");"
.SH ARGUMENTS
.IP "cmd" 12
Command data structure to initialize
.IP "nsid" 12
Return controllers that are attached to this nsid
.IP "cntid" 12
Starting CNTLID to return in the list
.IP "cntlist" 12
User space destination address to transfer the data
.SH "DESCRIPTION"
Initializes the passthru command buffer for the Identify command with
CNS value NVME_IDENTIFY_CNS_NS_CTRL_LIST.
