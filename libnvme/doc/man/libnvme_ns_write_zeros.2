.TH "libnvme_ns_write_zeros" 9 "libnvme_ns_write_zeros" "April 2026" "libnvme API manual" LINUX
.SH NAME
libnvme_ns_write_zeros \- Write zeros to a namespace
.SH SYNOPSIS
.B "int" libnvme_ns_write_zeros
.BI "(libnvme_ns_t n "  ","
.BI "off_t offset "  ","
.BI "size_t count "  ");"
.SH ARGUMENTS
.IP "n" 12
Namespace instance
.IP "offset" 12
LBA offset in \fIn\fP
.IP "count" 12
Number of sectors to be written
.SH "RETURN"
Number of sectors written
