.TH "nvme_init_get_log_phy_rx_eom" 9 "nvme_init_get_log_phy_rx_eom" "April 2026" "libnvme API manual" LINUX
.SH NAME
nvme_init_get_log_phy_rx_eom \- Initialize passthru command for Physical Interface Receiver Eye Opening Measurement
.SH SYNOPSIS
.B "void" nvme_init_get_log_phy_rx_eom
.BI "(struct libnvme_passthru_cmd *cmd "  ","
.BI "__u8 lsp "  ","
.BI "__u16 controller "  ","
.BI "struct nvme_phy_rx_eom_log *log "  ","
.BI "__u32 len "  ");"
.SH ARGUMENTS
.IP "cmd" 12
Passthru command to use
.IP "lsp" 12
Log specific, controls action and measurement quality
.IP "controller" 12
Target controller ID
.IP "log" 12
User address to store the log page
.IP "len" 12
The allocated size, minimum
struct nvme_phy_rx_eom_log
.SH "DESCRIPTION"
Initializes the passthru command buffer for the Get Log command with
LID value NVME_LOG_LID_PHY_RX_EOM
