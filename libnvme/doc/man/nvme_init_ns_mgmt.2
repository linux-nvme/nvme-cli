.TH "nvme_init_ns_mgmt" 9 "nvme_init_ns_mgmt" "April 2026" "libnvme API manual" LINUX
.SH NAME
nvme_init_ns_mgmt \- Initialize passthru command for Namespace Management
.SH SYNOPSIS
.B "void" nvme_init_ns_mgmt
.BI "(struct libnvme_passthru_cmd *cmd "  ","
.BI "__u32 nsid "  ","
.BI "enum nvme_ns_mgmt_sel sel "  ","
.BI "__u8 csi "  ","
.BI "struct nvme_ns_mgmt_host_sw_specified *data "  ");"
.SH ARGUMENTS
.IP "cmd" 12
Passthru command to use
.IP "nsid" 12
Namespace identifier
.IP "sel" 12
Type of management operation to perform
.IP "csi" 12
Command Set Identifier
.IP "data" 12
Host Software Specified Fields buffer
.SH "DESCRIPTION"
Initializes the passthru command buffer for the Namespace Management command.
