.TH "nvme_lookup_keyring" 9 "nvme_lookup_keyring" "March 2026" "libnvme API manual" LINUX
.SH NAME
nvme_lookup_keyring \- Lookup keyring serial number
.SH SYNOPSIS
.B "int" nvme_lookup_keyring
.BI "(struct nvme_global_ctx *ctx "  ","
.BI "const char *keyring "  ","
.BI "long *key "  ");"
.SH ARGUMENTS
.IP "ctx" 12
struct nvme_global_ctx object
.IP "keyring" 12
Keyring name
.IP "key" 12
Key serial number to return
.SH "DESCRIPTION"
Looks up the serial number of the keyring \fIkeyring\fP.
.SH "RETURN"
0 on success or negative error code otherwise
