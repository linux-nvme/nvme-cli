.TH "libnvme_set_logging_level" 9 "libnvme_set_logging_level" "April 2026" "libnvme API manual" LINUX
.SH NAME
libnvme_set_logging_level \- Set current logging level
.SH SYNOPSIS
.B "void" libnvme_set_logging_level
.BI "(struct libnvme_global_ctx *ctx "  ","
.BI "int log_level "  ","
.BI "bool log_pid "  ","
.BI "bool log_tstamp "  ");"
.SH ARGUMENTS
.IP "ctx" 12
struct libnvme_global_ctx object
.IP "log_level" 12
Logging level to set
.IP "log_pid" 12
Boolean to enable logging of the PID
.IP "log_tstamp" 12
Boolean to enable logging of the timestamp
.SH "DESCRIPTION"
Sets the current logging level for the global context.
